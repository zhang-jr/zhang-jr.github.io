---
import { ABOUT, EXPERIENCE } from '@data/site';
---

<section id="about">
  <div class="fade-up">
    <div class="section-tag">// 01 · About</div>
    <h2 class="section-title">About<br/>Me</h2>
    <br />
    <div class="about-text">
      {ABOUT.bio.map((p) => <p>{p}</p>)}
    </div>
  </div>

  <div class="timeline fade-up">
    <div class="section-tag">// Experience</div>
    <br />
    {EXPERIENCE.map(({ year, role, company, desc }) => (
      <div class="timeline-item">
        <span class="timeline-year">{year}</span>
        <div class="timeline-content">
          <h4>{role} · {company}</h4>
          <p>{desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  #about {
    padding: 120px 48px;
    border-top: 1px solid var(--border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .about-text {
    font-weight: 300;
    line-height: 2;
    color: var(--text-dim);
    font-size: 0.95rem;
  }
  .about-text p + p { margin-top: 20px; }

  .timeline { display: flex; flex-direction: column; }
  .timeline-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-year {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    padding-top: 4px;
  }
  .timeline-content h4 {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 4px;
  }
  .timeline-content p {
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    #about { grid-template-columns: 1fr; padding: 80px 24px; }
  }
</style>
