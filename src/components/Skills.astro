---
import { SKILLS } from '@data/site';
---

<section id="skills">
  <div class="skills-header fade-up">
    <div>
      <div class="section-tag">// 02 · Skills</div>
      <h2 class="section-title">Technical<br/>Stack</h2>
    </div>
  </div>

  <div class="skills-grid">
    {SKILLS.map(({ icon, name, desc, tags }) => (
      <div class="skill-card fade-up">
        <span class="skill-icon">{icon}</span>
        <div class="skill-name">{name}</div>
        <div class="skill-desc">{desc}</div>
        <div class="skill-tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  #skills {
    padding: 120px 48px;
    border-top: 1px solid var(--border);
  }
  .skills-header {
    margin-bottom: 64px;
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  .skill-card {
    background: var(--card);
    padding: 36px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .skill-card:hover { background: #1a1a2e; }
  .skill-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--accent);
    transition: height 0.4s ease;
  }
  .skill-card:hover::before { height: 100%; }
  .skill-icon {
    font-size: 1.5rem;
    margin-bottom: 16px;
    display: block;
  }
  .skill-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 8px;
  }
  .skill-desc {
    font-size: 0.72rem;
    color: var(--text-dim);
    line-height: 1.7;
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 16px;
  }

  @media (max-width: 768px) {
    #skills { padding: 80px 24px; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
