---
import { SITE, STATS } from '@data/site';
---

<section id="hero">
  <div class="hero-number">01</div>

  <div class="hero-badge">
    <span class="dot"></span>
    {SITE.tagline}
  </div>

  <h1 class="hero-title">
    <span class="name-solid">{SITE.name.split(' ')[0].toUpperCase()}</span>
    <span class="name-outline">{SITE.name.split(' ').slice(1).join(' ').toUpperCase()}</span>
  </h1>

  <div class="hero-meta">
    <p class="hero-desc">{SITE.description}</p>
    <div class="hero-stats">
      {STATS.map(({ num, label }) => (
        <div class="stat-item">
          <div class="stat-num">{num}</div>
          <div class="stat-label">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 48px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-number {
    position: absolute;
    top: 50%;
    right: -40px;
    transform: translateY(-50%) rotate(90deg);
    font-family: 'Syne', sans-serif;
    font-size: 22vw;
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(232,255,71,0.06);
    letter-spacing: -0.05em;
    pointer-events: none;
    white-space: nowrap;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border);
    padding: 6px 14px;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 32px;
    width: fit-content;
  }
  .dot {
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 9vw, 9rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin-bottom: 40px;
  }
  .name-solid { display: block; color: var(--text); }
  .name-outline {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1px var(--accent);
  }
  .hero-meta {
    display: flex;
    gap: 60px;
    align-items: flex-end;
  }
  .hero-desc {
    max-width: 480px;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-dim);
  }
  .hero-stats {
    display: flex;
    gap: 40px;
    flex-shrink: 0;
  }
  .stat-item { text-align: right; }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 4px;
  }
  .scroll-hint {
    position: absolute;
    bottom: 40px;
    right: 48px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .scroll-line {
    width: 60px; height: 1px;
    background: var(--muted);
    position: relative;
    overflow: hidden;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    left: -100%; top: 0;
    width: 100%; height: 100%;
    background: var(--accent);
    animation: scan 2s ease-in-out infinite;
  }
  @keyframes scan {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  @media (max-width: 768px) {
    #hero { padding: 0 24px 60px; }
    .hero-meta { flex-direction: column; gap: 32px; }
    .hero-stats { gap: 24px; }
  }
</style>
